{
  "name": "hotel-management-backend",
  "version": "1.0.0",
  "description": "Backend API for Hotel Management System",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node -r dotenv/config server.js",
    "dev": "nodemon -r dotenv/config server.js",
    "seed": "node -r dotenv/config data/seed.js",
