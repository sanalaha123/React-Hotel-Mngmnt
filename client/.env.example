# Frontend build-time configuration.
# Copy to `.env` for local overrides, or set these as build env vars in Choreo.
# Leave unset to use local-dev defaults (Vite proxy to http://localhost:5000).

# Full URL of the backend REST API (include the /api suffix).
# Example: https://<backend-choreo-url>/api
VITE_API_BASE_URL=

# Backend base URL for the Socket.IO / WebSocket connection (no /api suffix).
# Example: https://<backend-choreo-url>
VITE_SOCKET_URL=
